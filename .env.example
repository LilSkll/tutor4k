# Spanish Tutor — Environment Variables
# Copy this file to .env.local and fill in your values.

# Public site URL (used in password-reset emails). No trailing slash.
# Production example: https://spanish-tutor-psi.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- AI Providers ---
# Groq (primary, free/fast). Get a key at https://console.groq.com/keys
GROQ_API_KEY=YOUR-GROQ-KEY
GROQ_MODEL=llama-3.3-70b-versatile
# Optional extra Groq keys (only help if they are from different orgs):
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=

# DeepSeek (fallback when Groq rate-limits). https://platform.deepseek.com
DEEPSEEK_API_KEY=YOUR-DEEPSEEK-KEY
DEEPSEEK_MODEL=deepseek-v4-flash

# Google Gemini (optional last resort). https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR-GEMINI-KEY
GEMINI_MODEL=gemini-1.5-flash
